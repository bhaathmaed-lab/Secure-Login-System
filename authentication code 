import sqlite3


def connect():

    return sqlite3.connect(
        "users.db"
    )


def get_user(username):

    con=connect()

    cur=con.cursor()

    cur.execute(
        "SELECT * FROM users WHERE username=?",
        (username,)
    )

    user=cur.fetchone()

    con.close()

    return user